<Window x:Class="Lab1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lab1"
        mc:Ignorable="d"
        Title="One variable functional equations solver"
        WindowState="Maximized">
    <Window.Resources>
        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Background" Value="AntiqueWhite"/>
        </Style>
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="15">
                <TextBlock Text="Enter the equation: "/>
                <TextBox x:Name="equation" IsReadOnly="True" PreviewMouseDown="TextBox_Select"/>
                <TextBlock Text="Range (start): "/>
                <TextBox x:Name="start" IsReadOnly="True" PreviewMouseDown="TextBox_Select"/>
                <TextBlock Text="Range (end): "/>
                <TextBox x:Name="end" IsReadOnly="True" PreviewMouseDown="TextBox_Select"/>
                <TextBlock Text="Enter the epsilon: "/>
                <TextBox x:Name="eps" IsReadOnly="True" PreviewMouseDown="TextBox_Select"/>
                <Button Content="Solve" Click="Solve_Click"/>
            </StackPanel>

            <Grid  Margin="15" Grid.Column="1" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Content="С" Grid.Row="0" Grid.Column="0" Click="Clear_Click"/>
                <Button Content="e" Grid.Row="0" Grid.Column="1" Click="Special_Click"/>
                <Button Content="x" Grid.Row="0" Grid.Column="2" Click="Special_Click"/>
                <Button Content="." Grid.Row="0" Grid.Column="3" Click="Point_Click"/>
                <Button Content="←" Grid.Row="0" Grid.Column="4" Click="Backspace_Click"/>

                <Button Content="1" Grid.Row="1" Grid.Column="0" Click="AddText_Click"/>
                <Button Content="2" Grid.Row="1" Grid.Column="1" Click="AddText_Click"/>
                <Button Content="3" Grid.Row="1" Grid.Column="2" Click="AddText_Click"/>
                <Button Content="+" Grid.Row="1" Grid.Column="3" Click="Operator_Click"/>
                <Button Content="-" Grid.Row="1" Grid.Column="4" Click="Minus_Click"/>

                <Button Content="4" Grid.Row="2" Grid.Column="0" Click="AddText_Click"/>
                <Button Content="5" Grid.Row="2" Grid.Column="1" Click="AddText_Click"/>
                <Button Content="6" Grid.Row="2" Grid.Column="2" Click="AddText_Click"/>
                <Button Content="*" Grid.Row="2" Grid.Column="3" Click="Operator_Click"/>
                <Button Content="/" Grid.Row="2" Grid.Column="4" Click="Operator_Click"/>

                <Button Content="7" Grid.Row="3" Grid.Column="0" Click="AddText_Click"/>
                <Button Content="8" Grid.Row="3" Grid.Column="1" Click="AddText_Click"/>
                <Button Content="9" Grid.Row="3" Grid.Column="2" Click="AddText_Click"/>
                <Button Content="PI" Grid.Row="3" Grid.Column="3" Click="AddText_Click"/>
                <Button Content="^" Grid.Row="3" Grid.Column="4" Click="Operator_Click"/>

                <Button Content="(" Grid.Row="4" Grid.Column="0" Click="AddText_Click"/>
                <Button Content="0" Grid.Row="4" Grid.Column="1" Click="AddText_Click"/>
                <Button Content=")" Grid.Row="4" Grid.Column="2" Click="CloseBracket_Click"/>
                <Button Content="Sin" Grid.Row="4" Grid.Column="3" Click="Function_Click"/>
                <Button Content="Cos" Grid.Row="4" Grid.Column="4" Click="Function_Click"/>

            </Grid>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <TextBlock x:Name="res" FontSize="16"/>
        </ScrollViewer>
    </Grid>
</Window>
